# =============================================================================
# Incident Intel - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's in .gitignore)

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# -----------------------------------------------------------------------------
# Database (PostgreSQL with pgvector)
# -----------------------------------------------------------------------------
# Local dev (docker-compose Postgres):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/incident_intel

# Prod ONLY — Neon DIRECT URL (no "-pooler" in host); used by Alembic for migrations.
# Leave blank locally: env.py falls back to DATABASE_URL.
DATABASE_URL_DIRECT=

# For testing:
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/incident_intel_test

ECHO_SQL=false  # Set to "true" to log SQL queries, "debug" for verbose output

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
# Used for: caching embeddings, search results, rate limiting
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=86400

# -----------------------------------------------------------------------------
# OpenAI API
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL_CHAT=gpt-4o  # or gpt-4o-mini for development
OPENAI_MODEL_EMBEDDING=text-embedding-3-small  # or text-embedding-3-large for higher quality
OPENAI_MODEL_CLASSIFICATION=gpt-4o  # or gpt-4o-mini for development

# -----------------------------------------------------------------------------
# Minimum cosine similarity
# -----------------------------------------------------------------------------
# Minimum cosine similarity (0-1) for vector search results.
# Lower = lets more results through (including weaker matches).
MIN_VECTOR_SIMILARITY=0.3  # ~0.2–0.3 = vague semantic overlap, ~0.4–0.6 = loosely related

# CORS — comma-separated EXACT origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Prod only: anchored regex for Vercel preview URLs. Blank locally.
CORS_ALLOWED_ORIGIN_REGEX=