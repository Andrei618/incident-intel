# =============================================================================
# Incident Intel - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's in .gitignore)

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development  # development or production
DEBUG=true  # FastAPI setting, set "false" in production
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# -----------------------------------------------------------------------------
# Database (PostgreSQL with pgvector)
# -----------------------------------------------------------------------------
# Railway PostgreSQL 18 with pgvector 0.8.1 (verified 2026-01-07)
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@YOUR_HOST.proxy.rlwy.net:PORT/railway

# Local development (Docker):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/incident_intel

# For testing:
TEST_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/incident_intel_test

ECHO_SQL=false  # Set to "true" to log SQL queries, "debug" for verbose output

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
# Used for: caching embeddings, search results, rate limiting
REDIS_URL=redis://localhost:6379/0
# For testing:
TEST_REDIS_URL=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# OpenAI API
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o  # or gpt-4o-mini for development

# -----------------------------------------------------------------------------
# LangSmith (Optional - for LangChain debugging/monitoring)
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=incident-intel

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-for-sessions-and-tokens-min-32-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
# Set to true to enable hot reload of FastAPI server in development
RELOAD=true  # set false in production